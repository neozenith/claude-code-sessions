graph LR
    S1["~/.claude/projects/<br/>Session JSONL Files"]
    S2["rsync to ./projects/<br/>(optional local copy)"]

    I1["CacheManager<br/>Scan mtimes → pick<br/>new / modified files"]
    I2["_parse_event()<br/>+ compute_event_costs()<br/>(hardcoded pricing dict)"]
    I3["SQLite inserts<br/>events, event_calls,<br/>agg, sessions, projects"]

    D1["~/.claude/cache/<br/>introspect_sessions.db"]

    A1["FastAPI Endpoints<br/>/api/summary, /api/usage/*<br/>/api/calls/*, /api/projects"]

    F1["React Frontend<br/>Fetch JSON Data"]
    F2["Plotly.js<br/>Render Charts"]

    S1 --> S2
    S2 --> I1
    S1 --> I1
    I1 --> I2
    I2 --> I3
    I3 --> D1
    D1 --> A1
    A1 --> F1
    F1 --> F2

